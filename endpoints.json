{
  "api": {
    "description": "Edugreen API Gateway",
    "version": "1.0.0",
    "global_middleware": {
      "name": "ApiKeyMiddleware",
      "description": "Aplicado a todos los endpoints. Valida que el header Authorization coincida con la variable de entorno API_KEY.",
      "header_required": {
        "Authorization": "string — valor igual a API_KEY del entorno"
      },
      "errors": {
        "401": "No se envió el header Authorization",
        "403": "El valor de Authorization no coincide con API_KEY"
      }
    }
  },
  "endpoints": [
    {
      "path": "/health",
      "method": "GET",
      "controller": "HealthController",
      "action": "get",
      "description": "Comprueba que la API está online y devuelve información básica del servicio.",
      "implemented": true,
      "auth_required": true,
      "parameters": {
        "headers": {},
        "params": {},
        "query": {},
        "body": {}
      },
      "responses": {
        "200": {
          "description": "API operativa",
          "schema": {
            "name": "string — nombre del servicio ('api-gateway')",
            "url": "string — URL local del servidor",
            "online": "boolean — siempre true si responde"
          }
        },
        "500": {
          "description": "Error interno del servidor"
        }
      }
    },
    {
      "path": "/auth",
      "method": "POST",
      "controller": "AuthController",
      "action": "createUser",
      "description": "Registra un nuevo usuario. Hashea la contraseña y devuelve un accessToken (1h) y un refreshToken (7d).",
      "implemented": true,
      "auth_required": true,
      "parameters": {
        "headers": {},
        "params": {},
        "query": {},
        "body": {
          "name": "string — nombre del usuario",
          "lastName": "string — apellido del usuario",
          "email": "string — email único",
          "password": "string — contraseña en texto plano (se hashea con bcrypt)"
        }
      },
      "responses": {
        "200": {
          "description": "Usuario creado correctamente",
          "schema": {
            "id": "string — UUID del usuario recién creado",
            "role": "string — rol asignado: 'student' | 'teacher' | 'admin'",
            "sessionToken": "string — JWT con payload {id, name, lastName, email, role}, expira en 1h",
            "refreshToken": "string — JWT con payload {id}, expira en 7d"
          }
        },
        "400": {
          "description": "Faltan campos obligatorios en el body"
        },
        "409": {
          "description": "El email ya está en uso"
        },
        "500": {
          "description": "Error interno del servidor"
        }
      }
    },
    {
      "path": "/auth",
      "method": "PATCH",
      "controller": "AuthController",
      "action": "forgotPassword",
      "description": "Solicita un token de recuperación de contraseña para el email indicado. El token JWT tiene una validez de 5 minutos.",
      "implemented": true,
      "auth_required": true,
      "parameters": {
        "headers": {},
        "params": {},
        "query": {},
        "body": {
          "email": "string — email del usuario que quiere recuperar contraseña"
        }
      },
      "responses": {
        "200": {
          "description": "Token de recuperación generado",
          "schema": {
            "token": "string — JWT con payload {id, email}, expira en 5min"
          }
        },
        "400": {
          "description": "Falta el campo email"
        },
        "404": {
          "description": "No existe ningún usuario con ese email"
        },
        "500": {
          "description": "Error interno del servidor"
        }
      }
    },
    {
      "path": "/auth/login",
      "method": "POST",
      "controller": "AuthController",
      "action": "login",
      "description": "Autentica un usuario con email y contraseña. Si son correctos devuelve un accessToken (1h) y un refreshToken (7d).",
      "implemented": true,
      "auth_required": true,
      "parameters": {
        "headers": {},
        "params": {},
        "query": {},
        "body": {
          "email": "string — email del usuario",
          "password": "string — contraseña en texto plano"
        }
      },
      "responses": {
        "200": {
          "description": "Login correcto",
          "schema": {
            "id": "string — UUID del usuario",
            "role": "string — rol del usuario: 'student' | 'teacher' | 'admin'",
            "sessionToken": "string — JWT con payload {id, name, lastName, email, role}, expira en 1h",
            "refreshToken": "string — JWT con payload {id}, expira en 7d"
          }
        },
        "400": {
          "description": "Faltan email o password"
        },
        "401": {
          "description": "Contraseña incorrecta"
        },
        "404": {
          "description": "No existe ningún usuario con ese email"
        },
        "500": {
          "description": "Error interno del servidor"
        }
      }
    },
    {
      "path": "/auth/refresh",
      "method": "POST",
      "controller": "AuthController",
      "action": "refreshSession",
      "description": "Genera un nuevo accessToken a partir de un refreshToken válido. Usar cuando el accessToken haya expirado.",
      "implemented": true,
      "auth_required": true,
      "parameters": {
        "headers": {},
        "params": {},
        "query": {},
        "body": {
          "refreshToken": "string — JWT de refresco obtenido en POST /auth (válido 7d)"
        }
      },
      "responses": {
        "200": {
          "description": "Nuevo sessionToken generado",
          "schema": {
            "sessionToken": "string — JWT con payload {id, name, lastName, email, role}, expira en 1h"
          }
        },
        "400": {
          "description": "Falta el campo refreshToken"
        },
        "401": {
          "description": "refreshToken inválido o expirado"
        },
        "404": {
          "description": "Usuario no encontrado"
        },
        "500": {
          "description": "Error interno del servidor"
        }
      }
    },
    {
      "path": "/auth/:token",
      "method": "PATCH",
      "controller": "AuthController",
      "action": "changePassword",
      "description": "Cambia la contraseña del usuario usando el token de recuperación obtenido en PATCH /auth. El token se verifica y se extrae el email del payload.",
      "implemented": true,
      "auth_required": true,
      "parameters": {
        "headers": {},
        "params": {
          "token": "string — JWT de recuperación obtenido en PATCH /auth (válido 5min)"
        },
        "query": {},
        "body": {
          "password": "string — nueva contraseña en texto plano (se hashea con bcrypt)"
        }
      },
      "responses": {
        "200": {
          "description": "Contraseña actualizada correctamente",
          "schema": {
            "message": "string — 'Password updated successfully'"
          }
        },
        "400": {
          "description": "Falta el token en la ruta o la nueva contraseña en el body"
        },
        "401": {
          "description": "Token inválido o expirado"
        },
        "404": {
          "description": "Usuario no encontrado"
        },
        "500": {
          "description": "Error interno del servidor"
        }
      }
    },
    {
      "path": "/user",
      "method": "GET",
      "controller": "UserController",
      "action": "checkUserExists",
      "description": "Comprueba si existe un usuario con el email indicado. Devuelve un booleano, sin exponer datos del usuario.",
      "implemented": true,
      "auth_required": true,
      "parameters": {
        "headers": {},
        "params": {},
        "query": {
          "email": "string — email a comprobar"
        },
        "body": {}
      },
      "responses": {
        "200": {
          "description": "Consulta resuelta",
          "schema": {
            "exists": "boolean — true si el email está registrado, false si no"
          }
        },
        "400": {
          "description": "Falta el query param email"
        },
        "500": {
          "description": "Error interno del servidor"
        }
      }
    },
    {
      "path": "/user/:id",
      "method": "GET",
      "controller": "UserController",
      "action": "getOne",
      "description": "Devuelve los datos de un usuario por su UUID.",
      "implemented": true,
      "auth_required": true,
      "parameters": {
        "headers": {},
        "params": {
          "id": "string — UUID del usuario"
        },
        "query": {},
        "body": {}
      },
      "responses": {
        "200": {
          "description": "Datos del usuario",
          "schema": {
            "id": "string — UUID",
            "name": "string",
            "lastName": "string",
            "email": "string",
            "role": "string — 'student' | 'teacher' | 'admin'",
            "institution_id": "string | null — UUID de la institución",
            "created_at": "datetime | null",
            "updated_at": "datetime | null",
            "last_login_at": "datetime | null"
          }
        },
        "400": {
          "description": "Falta el parámetro id"
        },
        "404": {
          "description": "Usuario no encontrado"
        },
        "500": {
          "description": "Error interno del servidor"
        }
      }
    },
    {
      "path": "/user/:id",
      "method": "PATCH",
      "controller": "UserController",
      "action": "updateOne",
      "description": "Actualiza los datos de un usuario. Solo se modifican los campos enviados en el body.",
      "implemented": true,
      "auth_required": true,
      "parameters": {
        "headers": {},
        "params": {
          "id": "string — UUID del usuario"
        },
        "query": {},
        "body": {
          "name": "string — (opcional) nuevo nombre",
          "lastName": "string — (opcional) nuevo apellido",
          "email": "string — (opcional) nuevo email, debe ser único"
        }
      },
      "responses": {
        "200": {
          "description": "Usuario actualizado correctamente",
          "schema": {
            "message": "string — 'User updated successfully'"
          }
        },
        "400": {
          "description": "Falta el parámetro id o el body está vacío"
        },
        "404": {
          "description": "Usuario no encontrado"
        },
        "409": {
          "description": "El email ya está en uso por otro usuario"
        },
        "500": {
          "description": "Error interno del servidor"
        }
      }
    },
    {
      "path": "/user/:id",
      "method": "DELETE",
      "controller": "UserController",
      "action": "deleteOne",
      "description": "Elimina un usuario por su UUID.",
      "implemented": true,
      "auth_required": true,
      "parameters": {
        "headers": {},
        "params": {
          "id": "string — UUID del usuario"
        },
        "query": {},
        "body": {}
      },
      "responses": {
        "200": {
          "description": "Usuario eliminado correctamente",
          "schema": {
            "message": "string — 'User deleted successfully'"
          }
        },
        "400": {
          "description": "Falta el parámetro id"
        },
        "404": {
          "description": "Usuario no encontrado"
        },
        "500": {
          "description": "Error interno del servidor"
        }
      }
    },
    {
      "path": "/user/:id/challenges",
      "method": "GET",
      "controller": "UserController",
      "action": "getChallenges",
      "description": "Devuelve el historial de retos del usuario: todos los desafíos en los que está inscrito, con detalles del reto, estado (completed | in_progress) y fechas.",
      "implemented": true,
      "auth_required": true,
      "parameters": {
        "headers": { "x-session-token": "string — JWT de sesión" },
        "params": { "id": "string — UUID del usuario" },
        "query": {},
        "body": {}
      },
      "responses": {
        "200": {
          "description": "Lista de retos del usuario",
          "schema": {
            "data": "array — [{ challenge_id, challenge_name, description, points, class_id, enrolled_at, completed_at, status: 'completed' | 'in_progress' }]"
          }
        },
        "400": { "description": "Falta el parámetro id" },
        "404": { "description": "Usuario no encontrado" },
        "500": { "description": "Error interno del servidor" }
      }
    },
    {
      "path": "/class",
      "method": "POST",
      "controller": "ClassController",
      "action": "create",
      "description": "Crea una nueva clase asignada a un tutor.",
      "implemented": true,
      "auth_required": true,
      "roles_required": ["teacher", "admin"],
      "parameters": {
        "headers": { "x-session-token": "string — JWT de sesión" },
        "params": {},
        "query": {},
        "body": {
          "name": "string — nombre de la clase",
          "tutor_id": "string — UUID del usuario tutor",
          "description": "string — (opcional) descripción de la clase"
        }
      },
      "responses": {
        "200": { "description": "Clase creada", "schema": { "id": "string — UUID de la clase creada" } },
        "400": { "description": "Faltan name o tutor_id" },
        "403": { "description": "El usuario no tiene permisos (rol student)" },
        "500": { "description": "Error interno del servidor" }
      }
    },
    {
      "path": "/class/:id",
      "method": "GET",
      "controller": "ClassController",
      "action": "getOne",
      "description": "Devuelve los datos de una clase por su UUID.",
      "implemented": true,
      "auth_required": true,
      "parameters": {
        "headers": { "x-session-token": "string — JWT de sesión" },
        "params": { "id": "string — UUID de la clase" },
        "query": {},
        "body": {}
      },
      "responses": {
        "200": { "description": "Datos de la clase", "schema": { "id": "string", "name": "string", "tutor_id": "string", "description": "string|null", "created_at": "datetime", "updated_at": "datetime" } },
        "404": { "description": "Clase no encontrada" },
        "500": { "description": "Error interno del servidor" }
      }
    },
    {
      "path": "/class/:id",
      "method": "PATCH",
      "controller": "ClassController",
      "action": "updateOne",
      "description": "Actualiza los datos de una clase. Solo se modifican los campos enviados.",
      "implemented": true,
      "auth_required": true,
      "parameters": {
        "headers": { "x-session-token": "string — JWT de sesión" },
        "params": { "id": "string — UUID de la clase" },
