      },
      "responses": {
        "200": { "description": "Datos de la institución", "schema": { "id": "string", "name": "string", "student_domain": "string", "teacher_domain": "string", "created_at": "datetime" } },
        "404": { "description": "Institución no encontrada" },
        "500": { "description": "Error interno del servidor" }
      }
    },
