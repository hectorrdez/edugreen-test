          "name": "string — (opcional) nuevo nombre",
          "description": "string — (opcional) nueva descripción"
        }
      },
      "responses": {
        "200": { "description": "Clase actualizada", "schema": { "message": "string" } },
        "400": { "description": "Falta id o body vacío" },
        "404": { "description": "Clase no encontrada" },
        "500": { "description": "Error interno del servidor" }
      }
    },
    {
      "path": "/class/:id",
      "method": "DELETE",
      "controller": "ClassController",
      "action": "deleteOne",
      "description": "Elimina una clase por su UUID. Elimina en cascada sus challenges y matrículas.",
      "implemented": true,
      "auth_required": true,
      "parameters": {
        "headers": { "x-session-token": "string — JWT de sesión" },
        "params": { "id": "string — UUID de la clase" },
        "query": {},
        "body": {}
      },
      "responses": {
        "200": { "description": "Clase eliminada", "schema": { "message": "string" } },
        "404": { "description": "Clase no encontrada" },
        "500": { "description": "Error interno del servidor" }
      }
    },
    {
      "path": "/institution",
      "method": "POST",
