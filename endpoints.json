          "teacher_domain": "string — (opcional) nuevo dominio de profesores"
        }
      },
      "responses": {
        "200": { "description": "Institución actualizada", "schema": { "message": "string" } },
        "400": { "description": "Falta id o body vacío" },
        "403": { "description": "Solo admin puede modificar instituciones" },
        "404": { "description": "Institución no encontrada" },
        "500": { "description": "Error interno del servidor" }
